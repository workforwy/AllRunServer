# MySQL 连接配置（已迁移至 application.yml + 环境变量）
# 使用方式：
#   export DB_USER=root
#   export DB_PASSWORD=your_password
#
# 数据库需提前创建：
#   CREATE DATABASE IF NOT EXISTS all_run DEFAULT CHARACTER SET utf8mb4;

drivers=com.mysql.cj.jdbc.Driver
dbids=jdbc:mysql://localhost:3306/all_run?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
user=root
password=your_password_here
maxconns=10
